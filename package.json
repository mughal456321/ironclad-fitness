{
  "name": "ironclad-elite-fitness",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix frontend",
    "server": "tsx backend/index.ts",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "clean": "rm -rf frontend/dist backend/ironclad.db"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
